{
  "manifest_version": 3,
  "name": "DevBuddy",
  "version": "1.0",
  "description": "A Chrome extension that provides Some usefull tools for developers.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "/popup/popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
